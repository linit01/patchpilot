#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# PatchPilot — nuke-data.sh
# Wipes all node-local hostPath data directories so a fresh deploy starts
# with a clean database and volumes.
#
# Run this ON your k3s node (not your workstation) before re-deploying.
#
# Usage:
#   ssh k3s sudo bash nuke-data.sh
#   or copy and run locally as root on the k3s node
#
# WARNING: This is DESTRUCTIVE — all PatchPilot PostgreSQL data, Ansible
# inventory, and backups stored on this node will be permanently deleted.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

DATA_DIRS=(
  /app-data/patchpilot-postgres-data
  /app-data/patchpilot-backups
  /app-data/patchpilot-ansible-data
)

CONTAINERD_IMAGES=(
  "linit01/patchpilot"
)

echo -e "${RED}╔══════════════════════════════════════════════════════╗${NC}"
echo -e "${RED}║  PatchPilot — FULL DATA WIPE                         ║${NC}"
echo -e "${RED}║  This will delete all PatchPilot data on this node.  ║${NC}"
echo -e "${RED}╚══════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${YELLOW}Directories to remove:${NC}"
for d in "${DATA_DIRS[@]}"; do
  if [ -d "$d" ]; then
    echo "  [EXISTS]  $d"
  else
    echo "  [ABSENT]  $d"
  fi
done
echo ""
read -rp "Type 'yes' to confirm wipe: " CONFIRM
if [ "$CONFIRM" != "yes" ]; then
  echo "Aborted."
  exit 0
fi

echo ""
echo "── Removing hostPath data directories ──────────────────────────────────"
for d in "${DATA_DIRS[@]}"; do
  if [ -d "$d" ]; then
    rm -rf "$d"
    echo -e "  ${GREEN}Removed${NC}: $d"
  else
    echo "  Skipped (not found): $d"
  fi
done

echo ""
echo "── Purging PatchPilot images from containerd ───────────────────────────"
if command -v crictl &>/dev/null; then
  IMAGES=$(crictl images 2>/dev/null | grep -E "linit01/patchpilot" | awk '{print $3}' || true)
  if [ -n "$IMAGES" ]; then
    echo "$IMAGES" | xargs -r crictl rmi
    echo -e "  ${GREEN}Images removed.${NC}"
  else
    echo "  No PatchPilot images found in containerd cache."
  fi
else
  echo -e "  ${YELLOW}crictl not found — skipping containerd cache purge.${NC}"
  echo "  If you use k3s, run: sudo k3s crictl rmi \$(sudo k3s crictl images | grep patchpilot | awk '{print \$3}')"
fi

echo ""
echo -e "${GREEN}Done. Safe to re-run install-k3s.sh now.${NC}"
