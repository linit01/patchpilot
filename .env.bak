# ─────────────────────────────────────────────────────────────────────────────
# PatchPilot — Environment Configuration Template
# cp .env.example .env  →  fill in your values  →  never commit .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=patchpilot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=patchpilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Encryption Key (NEVER share or commit this value) ─────────────────────────
# Generate:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PATCHPILOT_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# ── Application ───────────────────────────────────────────────────────────────
AUTO_REFRESH_INTERVAL=300
DEFAULT_SSH_USER=root
DEFAULT_SSH_PORT=22

# ── Network ───────────────────────────────────────────────────────────────────
# Default: plain HTTP on port 8080, open CORS (fine for LAN use)
APP_BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=*

# If you put a reverse proxy in front for HTTPS, update these:
# APP_BASE_URL=https://patchpilot.lan
# ALLOWED_ORIGINS=https://patchpilot.lan

# ── Backup ✚ ──────────────────────────────────────────────────────────────────
# BACKUP_RETAIN_COUNT=10
# MAX_BACKUP_SIZE_MB=500
# Install type — used by the web uninstaller (docker or k3s)
PATCHPILOT_INSTALL_MODE=docker

# ── Install path ───────────────────────────────────────────────────────────────
# Absolute path to the directory containing this .env file.
# Used by the backup module to include .env in uninstall backup bundles so a
# fresh install can be fully restored from the archive.
# Example:  INSTALL_DIR=/home/john/patchpilot
INSTALL_DIR=/path/to/patchpilot
