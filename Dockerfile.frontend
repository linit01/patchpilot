# ─────────────────────────────────────────────────────────────────────────────
# PatchPilot — Frontend Image
# Bakes static UI files and nginx config into nginx:alpine.
# No volume mounts or ConfigMaps required at runtime.
# ─────────────────────────────────────────────────────────────────────────────
FROM nginx:alpine

COPY frontend/ /usr/share/nginx/html/
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
